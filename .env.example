# ─── Telegram Bot ───
# BotFather dan olinadi
BOT_TOKEN=your_bot_token_here

# Bot egasi Telegram ID si
OWNER_ID=your_telegram_id_here

# ─── Kinolar saqlash (BACKUP) ───
# Bot admin bo'lgan kanal ID si (masalan: @mening_backup_kanalim)
BACKUP_CHANNEL_ID=@your_backup_channel

# ─── Katta kinolar uchun MTProto (ixtiyoriy) ───
API_ID=12345678
API_HASH=your_api_hash_here
TG_SESSION=your_session_here

# ─── WebApp URL ───
# Railway da deploy qilganingizdan keyin Railway bergan URL ga o'zgartiring
# Masalan: https://kino-bot-production.up.railway.app
WEBAPP_URL=https://your-railway-url.up.railway.app

# ─── Data papkasi (Railway Volume uchun) ───
# Railway da Settings > Volumes > Mount path: /data
INSTANCE_DIR=/data

# ─── AI tavsiya uchun (ixtiyoriy) ───
ANTHROPIC_API_KEY=your_anthropic_api_key_here
